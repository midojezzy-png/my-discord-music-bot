{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"],
      "aptPackages": ["ffmpeg"],
      "variables": {
        "PYTHON_VERSION": "3.11"
      }
    }
  },
  "deploy": {
    "startCommand": "python Discord_Music_Bot.py"
  }
}
